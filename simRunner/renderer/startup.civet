"civet coffeeCompat"

import * as gpc from './../../gpc/gui.coffee'

ipcRenderer := window.ipcRenderer
reactClient := require 'react-dom/client';

ipcRenderer.on "set-config", async (e, CONFIG) =>
  debugGui := gpc.default.start(CONFIG)
  if debugGui.initWindow?
    container := document.getElementById("root")
    await reactClient.createRoot(container!).render(await debugGui.initWindow())
  window.lru = debugGui
  debugGui.start()

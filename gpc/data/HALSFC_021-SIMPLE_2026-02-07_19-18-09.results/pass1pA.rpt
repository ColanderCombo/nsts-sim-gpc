STMT                                                  SOURCE                                                  CURRENT SCOPE

   1 M| SIMPLE:                                                                                             |SIMPLE
   1 M| PROGRAM;                                                                                            |SIMPLE

     C|  CODE IN THIS TYPEFACE IS                                                                           |SIMPLE
   2 M|   DECLARE PI CONSTANT(3.14159266);                                                                  |SIMPLE
   3 M|   DECLARE R SCALAR;                                                                                 |SIMPLE
   4 M|   WRITE(6) 'Input R to compute PI R**2, or -1 to quit.';                                            |SIMPLE
   5 M|   DO WHILE TRUE;                                                                                    |SIMPLE
   6 M| 1   READ(5) R;                                                                                      |SIMPLE
   7 M| 1   IF R < 0 THEN                                                                                   |SIMPLE
   8 M| 1     EXIT;                                                                                         |SIMPLE

     E|                                             2                                                       | 
   9 M| 1   WRITE(6) 'R =', R, 'and PI R**2 =', PI R ;                                                      |SIMPLE
  10 M|   END;                                                                                              |ST#5

     C|  %SVCI(0);                                                                                          |SIMPLE
  11 M| CLOSE SIMPLE;                                                                                       |SIMPLE

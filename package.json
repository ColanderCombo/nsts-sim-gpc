{
  "name": "nsts-sim-gpc",
  "version": "1.0.0",
  "description": "Space Shuttle AP-101 GPC Simulator",
  "author": "Donald Schmidt <daschmid@gmail.com>",
  "license": "MIT",
  "main": "dist/main/main.js",
  "scripts": {
    "gui:dev": "electron-esbuild dev",
    "gui:build": "electron-esbuild build",
    "gpc:build": "node esbuild/esbuild.gpc.config.js",
    "gpc": "node dist/gpc.js",
    "dist:prep": "electron-esbuild build && node esbuild/esbuild.gpc.config.js",
    "dist:pkg": "npm run dist:prep && electron-builder",
    "dist:linux": "npm run dist:prep && electron-builder --linux",
    "dist:mac": "npm run dist:prep && electron-builder --mac"
  },
  "build": {
    "appId": "com.nsts.gpc",
    "productName": "GPC",
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "!**/*.map"
    ],
    "extraMetadata": {
      "main": "dist/main/main.js"
    },
    "asar": true,
    "linux": {
      "target": [ "AppImage" ],
      "category": "Development",
      "executableName": "gpc",
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    },
    "appImage": {
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "category": "public.app-category.developer-tools",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    }
  },
  "devDependencies": {
    "@babel/preset-react": "7.23.3",
    "electron": "27.3.11",
    "electron-builder": "24.13.3",
    "electron-devtools-installer": "3.2.0",
    "electron-esbuild": "8.0.0",
    "esbuild": "0.18.20",
    "esbuild-coffeescript": "2.2.0",
    "esbuild-plugin-svg": "0.1.0",
    "esbuild-plugin-wasm": "1.1.0",
    "typescript": "5.2.2"
  },
  "dependencies": {
    "@danielx/civet": "0.6.93",
    "@electron/remote": "2.1.2",
    "commander": "14.0.3",
    "lit": "^3.3.2",
    "long": "5.3.2",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  }
}
